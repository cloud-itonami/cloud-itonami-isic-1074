{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the kotoba-lang org of this workspace. This repo is standalone
 ;; (forkable outside the workspace); the :local/root path only resolves
 ;; inside the monorepo checkout -- a standalone fork should override it
 ;; with git coordinates (see the deps.edn of an already-fixed sibling,
 ;; e.g. cloud-itonami-isic-869 / cloud-itonami-isic-1071, which pin
 ;; langgraph via :git/sha for exactly this reason).
 ;;
 ;; PRIOR BUG (fixed here): this dependency previously existed ONLY under
 ;; the `:dev` alias's `:override-deps`, with the base `:deps` map empty.
 ;; `:override-deps` only overrides a coordinate for a library ALREADY
 ;; present somewhere in the resolved dependency graph -- with no base
 ;; `:deps` entry for `io.github.kotoba-lang/langgraph` there was nothing
 ;; to override, so `langgraph.graph` was never actually resolvable on
 ;; ANY alias combination, including the ones `deps.edn` itself declares
 ;; as the run/test path (`:run`, `:test`, `:dev:test`). That is the
 ;; direct cause of `pastaops.operation` never having been able to
 ;; `:require [langgraph.graph]` in the first place.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "pastaops.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
